[MASTER]
# Ignore the virtual environment directory
ignore=venv

# Add src to the path so pylint can find the media_scribe package
init-hook='import sys; sys.path.append("src")'

[MESSAGES CONTROL]
# Disable some messages globally
# R0903: too-few-public-methods (Targeting Pydantic models)
disable=R0903

[FORMAT]
max-line-length=100
